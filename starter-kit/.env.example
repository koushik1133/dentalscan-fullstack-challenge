# Copy this file to .env and fill in a real Postgres connection string.
#
# For local dev the fastest option is Neon (https://neon.tech), free tier,
# 60 second signup with GitHub. On the project dashboard copy the
# connection string labelled "Prisma" or "psql" and paste it below.
#
# On Vercel, set the same variable inside the project's Environment
# Variables settings instead of committing it here.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
